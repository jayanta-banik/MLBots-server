map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# 1) ai.mlbots.in -> FastAPI via Gunicorn socket
server {
    listen 80;
    server_name _ ai.mlbots.in;

    location / {
        include proxy_params;
        proxy_pass http://unix:/home/pi/MLBots-server/python_backend/app.sock;
        #proxy_intercept_errors on;
        #uwsgi_intercept_errors  on;
        #error_page 404 =200 https://app.mlbots.in/error/brokenLink;
        #error_page 500 501 502 503 504 =200 https://app.mlbots.in/error/internal;
    }
    client_max_body_size 16M;
}

# 2) app.mlbots.in -> Vite static build
server {
    listen 80;
    server_name _ app.mlbots.in;

    root /home/pi/MLBots-server/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# 3) admin.mlbots.in -> admin static frontend
server {
    listen 80;
    server_name admin.mlbots.in;

    root /home/pi/MLBots-server/admin-dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# 4) api.mlbots.in over HTTP -> app_http.js on 3001
server {
    listen 80;
    server_name api.mlbots.in;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

# 5) api.mlbots.in over HTTPS -> app.js on 3000
server {
    listen 80;
    server_name api.mlbots.in;

    # ssl_certificate /etc/letsencrypt/live/api.mlbots.in/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api.mlbots.in/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
}

# 6) resources.mlbots.in -> static resources
server {
    root /home/pi/MLBots-server/static;
    server_name resource.mlbots.in;

    index goback.html;

    location / {
         try_files \$uri \$uri/ =404;
    }
}