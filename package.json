{
  "name": "mlbots-server-root",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "nodemon --trace-warnings app.js",
    "start:node": "node app.js",
    "dev:http": "nodemon --trace-warnings app_http.js",
    "start:node:http": "node app_http.js",
    "dev:frontend": "yarn --cwd frontend dev",
    "build:frontend": "yarn --cwd frontend build"
  },
  "engines": {
    "node": ">=20"
  },
  "imports": {
    "#service/*": "./node_backend/services/*.js",
    "#utils/*": "./node_backend/utils/*.js",
    "#models/*": "./node_backend/models/*.js",
    "#middleware/*": "./node_backend/middleware/*.js",
    "#constants/*": "./node_backend/constants/*.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv-cli": "^8.0.0",
    "dotenv": "^16.4.5",
    "pm2": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@prisma/client": "^7.7.0",
    "axios": "^1.8.4",
    "body-parser": "^1.20.3",
    "compression": "^1.7.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
    "eslint-plugin-promise": "^6.0.0",
    "eslint": "^9.25.1",
    "exceljs": "^4.4.0",
    "express-async-errors": "^3.1.1",
    "express": "^4.21.2",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "mjml": "^4.15.3",
    "module-alias": "^2.2.3",
    "moment-timezone": "^0.6.0",
    "multer": "^2.0.1",
    "nodemon": "^3.1.9",
    "openai": "^6.10.0",
    "prettier": "^3.5.3",
    "prisma-field-encryption": "^1.6.0",
    "prisma": "^7.7.0",
    "request_trimmer": "^1.0.0",
    "supertest": "^7.0.0",
    "uuid": "^11.1.0",
    "yarn": "^1.22.22",
    "zod": "^4.3.6"
  }
}
