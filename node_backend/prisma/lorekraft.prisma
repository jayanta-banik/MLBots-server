model char_image {
  id             Int           @id @default(autoincrement())
  race_id        Int
  character_type CharacterType
  url            String        @unique
  alt            String?
  created_at     DateTime      @default(now())

  race race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  @@index([race_id])
}

model character_class {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt
}

model magic_attribution {
  id              Int          @id @default(autoincrement())
  name            String       @unique
  is_base_element Boolean      @default(false)
  base_element    MagicElement
  created_at      DateTime     @default(now())
  updated_at      DateTime     @default(now()) @updatedAt

  components magic_attribution_component[] @relation("complex_magic")
  used_in    magic_attribution_component[] @relation("component_magic")
}

model magic_attribution_component {
  id                             Int @id @default(autoincrement())
  magic_attribution_id           Int
  component_magic_attribution_id Int

  magic_attribution magic_attribution @relation("complex_magic", fields: [magic_attribution_id], references: [id])
  component         magic_attribution @relation("component_magic", fields: [component_magic_attribution_id], references: [id])

  @@unique([magic_attribution_id, component_magic_attribution_id])
}

model magic_item {
  id               Int            @id @default(autoincrement())
  player_id        Int?
  name             String
  description      String?
  attribute_agment AttributeType?
  attribute_bonus  Float          @default(0.0)
  ability_type     AbilityType
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  player player? @relation(fields: [player_id], references: [id], onDelete: SetNull)

  @@index([player_id])
}

model occupation {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  players                   player[]
  player_side_jobs          player_side_job[]
  player_side_job_histories player_side_job_history[]
}

model race {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  char_images         char_image[]
  evolution_from      race_evolutions[]     @relation("evolution_from")
  evolution_to        race_evolutions[]     @relation("evolution_to")
  player_familiars    player_familiars[]
  players             player[]
  // generic properties
  race_affinity       race_affinity[]
  race_attributes     race_attributes[]
  race_character_type race_character_type[]
  race_resistances    race_resistances[]
  race_skills         race_skills[]
  race_types          race_types[]
  race_weaknesses     race_weaknesses[]
}

model race_affinity {
  id              Int          @id @default(autoincrement())
  race_id         Int
  affinity_type   AffinityType
  description     String? // e.g. "Fire" for elemental affinity, "Swords" for weapon affinity, etc.
  affinity_target String
  value           Float        @default(0.14) // default affinity bonus is 14%, can be adjusted based on playtesting and balance needs

  race race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  @@unique([race_id, affinity_type, affinity_target])
  @@index([race_id])
}

model race_attributes {
  id             Int           @id @default(autoincrement())
  race_id        Int
  attribute_type AttributeType
  value          Float         @default(0.0)

  race race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  @@unique([race_id, attribute_type])
  @@index([race_id])
}

model race_character_type {
  id             Int           @id @default(autoincrement())
  race_id        Int
  character_type CharacterType

  race race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  @@unique([race_id, character_type])
  @@index([race_id])
}

model race_evolutions {
  id Int @id @default(autoincrement())

  from_race_id Int
  to_race_id   Int

  from_race                 race                        @relation("evolution_from", fields: [from_race_id], references: [id])
  to_race                   race                        @relation("evolution_to", fields: [to_race_id], references: [id])
  race_evolution_conditions race_evolution_conditions[]

  @@unique([from_race_id, to_race_id])
  @@index([from_race_id])
  @@index([to_race_id])
}

model race_evolution_conditions {
  id              Int                    @id @default(autoincrement())
  evolution_id    Int
  condition_type  EvolutionConditionType
  condition_value String

  evolution race_evolutions @relation(fields: [evolution_id], references: [id], onDelete: Cascade)

  @@index([evolution_id])
}

model race_resistances {
  id          Int            @id @default(autoincrement())
  race_id     Int
  name        String
  type        ResistanceType
  description String? // e.g. "Fire" for elemental resistance, "Swords" for weapon resistance, etc.
  amount      Float          @default(0.5)

  race race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  @@unique([race_id, type])
  @@index([race_id])
}

model race_skills {
  id             Int     @id @default(autoincrement())
  race_id        Int
  skills_id      Int
  description    String? // optional description for how the skill manifests
  cooldown_time  Float   @default(1) // cooldown in secs, 0 for passive skills
  cooldown_turns Int     @default(2) // cooldown in turns, 0 for passive skills

  race  race   @relation(fields: [race_id], references: [id], onDelete: Cascade)
  skill skills @relation(fields: [skills_id], references: [id], onDelete: Cascade)

  @@unique([race_id, skills_id])
  @@index([race_id])
}

model race_types {
  id      Int      @id @default(autoincrement())
  race_id Int
  type    RaceType

  race race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  @@unique([race_id, type])
  @@index([race_id])
}

model race_weaknesses {
  id          Int            @id @default(autoincrement())
  race_id     Int
  name        String
  type        ResistanceType
  description String
  amount      Float          @default(50)

  race race @relation(fields: [race_id], references: [id], onDelete: Cascade)

  @@unique([race_id, name])
  @@index([race_id])
}

model skills {
  id             Int           @id @default(autoincrement())
  name           String        @unique
  description    String?
  ability_type   AbilityType
  cooldown_time  Float         @default(1) // cooldown in secs, 0 for passive skills
  cooldown_turns Int           @default(2) // cooldown in turns, 0 for passive skills
  raceSkills     race_skills[]
}

model player {
  id                 Int      @id @default(autoincrement())
  race_id            Int
  player_familiar_id Int?
  occupation_id      Int?
  name               String
  level              Int      @default(1)
  created_at         DateTime @default(now())
  updated_at         DateTime @default(now()) @updatedAt

  race                      race                       @relation(fields: [race_id], references: [id], onDelete: Restrict)
  player_familiars          player_familiars?          @relation(fields: [player_familiar_id], references: [id], onDelete: SetNull)
  occupation                occupation?                @relation(fields: [occupation_id], references: [id], onDelete: SetNull)
  player_attributes         player_attribute[]
  player_affinities         player_affinity[]
  player_skills             player_skill[]
  player_resistances        player_resistance[]
  player_magic_attributions player_magic_attribution[]
  player_side_jobs          player_side_job[]
  magic_items               magic_item[]
  playerClass               player_class?              @relation(fields: [player_classId], references: [id])
  player_classId            Int?
  playerSideJobHistories    player_side_job_history[]
  playerInventories         player_inventory[]

  @@index([race_id])
  @@index([player_familiar_id])
  @@index([occupation_id])
}

model player_affinity {
  id              Int          @id @default(autoincrement())
  player_id       Int
  affinity_type   AffinityType
  affinity_target String

  player player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([player_id, affinity_type, affinity_target])
  @@index([player_id])
}

model player_attribute {
  id             Int           @id @default(autoincrement())
  player_id      Int
  attribute_type AttributeType
  value          Float         @default(0.0)

  player player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([player_id, attribute_type])
  @@index([player_id])
}

model player_class {
  id         Int      @id @default(autoincrement())
  player_id  Int
  class_id   Int
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  players player[]
}

model player_familiars {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  race_id     Int
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  race    race     @relation(fields: [race_id], references: [id], onDelete: Cascade)
  players player[]
}

model player_inventory {
  id        Int    @id @default(autoincrement())
  player_id Int
  item_name String
  quantity  Int    @default(1)

  player player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([player_id, item_name])
  @@index([player_id])
}

model player_magic_attribution {
  id        Int          @id @default(autoincrement())
  player_id Int
  element   MagicElement
  potency   Float        @default(1.0)

  player player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([player_id, element])
  @@index([player_id])
}

model player_resistance {
  id          Int            @id @default(autoincrement())
  player_id   Int
  type        ResistanceType
  element     MagicElement?
  description String?
  amount      Float          @default(0.5)

  player player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([player_id, type, element])
  @@index([player_id])
}

model player_side_job {
  id                Int       @id @default(autoincrement())
  player_id         Int
  occupation_id     Int
  salary_multiplier Float     @default(0.5)
  buff_multiplier   Float     @default(0.5)
  started_at        DateTime  @default(now())
  ended_at          DateTime?

  player     player     @relation(fields: [player_id], references: [id], onDelete: Cascade)
  occupation occupation @relation(fields: [occupation_id], references: [id], onDelete: Restrict)

  @@unique([player_id, occupation_id])
  @@index([player_id])
  @@index([occupation_id])
}

model player_side_job_history {
  id                Int      @id @default(autoincrement())
  player_id         Int
  occupation_id     Int
  salary_multiplier Float    @default(0.5)
  buff_multiplier   Float    @default(0.5)
  started_at        DateTime
  ended_at          DateTime

  player     player     @relation(fields: [player_id], references: [id], onDelete: Cascade)
  occupation occupation @relation(fields: [occupation_id], references: [id], onDelete: Restrict)

  @@index([player_id])
  @@index([occupation_id])
}

model player_skill {
  id             Int         @id @default(autoincrement())
  player_id      Int
  ability_type   AbilityType
  cooldown_time  Float       @default(1) // cooldown in secs, 0 for passive skills
  cooldown_turns Int         @default(2) // cooldown in turns, 0 for passive skills
  skill_name     String

  player player @relation(fields: [player_id], references: [id], onDelete: Cascade)

  @@unique([player_id, skill_name])
  @@index([player_id])
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AbilityType {
  REGULAR
  HEAVY
  UNIQUE
  PASSIVE
}

enum AffinityType {
  ELEMENTAL // player or race has an affinity for a specific magic element, e.g. "Fire" or "Water"
  WEAPON // player or race has an affinity for a specific weapon type, e.g. "Swords" or "Bows"
  SPELL // player has an affinity for a specific spell or spell type, e.g. "Fireball" or "Healing Spells"
  SKILL // player has an affinity for a specific skill or skill type, e.g. "Stealth" or "Swordsmanship"
}

enum AttributeType {
  STRENGTH
  AGILITY
  PHYSICAL_DEFENSE
  MAGICAL_DEFENSE
  MANA
  INTELLIGENCE
  COURAGE
  PATIENCE
  EGO
  PRIDE
}

enum CharacterType {
  PLAYER
  ENEMY
  BOSS
  NPC
  MINION
  SLAVE
  FAMILIAR
  SUPPORT_CHARACTER
}

enum MagicElement {
  FIRE
  WATER
  AIR
  EARTH
  AETHER
  LIGHT
  DARK
}

enum ResistanceType {
  PHYSICAL
  MAGIC
  SPELLS
  DEBUFF
  MENTAL
  VITALITY
  ELEMENTAL
  RADIANT
  LEVEL_NULL // immunity to level-drain / nullification effects
}

enum RaceType {
  CELESTIAL
  BEAST
  BEASTFOLK
  DEMON
  DRAGON
  DWARF
  ELEMENTAL
  ELF
  GIANT
  GOBLIN
  HUMAN
  MACHINE
  ORC
  SPIRIT
  PLANT
  UNDEAD
}

enum EvolutionConditionType {
  LEVEL
  ITEM
  AFFINITY
  ATTRIBUTE
  TIME_OF_DAY
}
