generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

generator erd {
  // yarn add -D prisma-erd-generator @mermaid-js/mermaid-cli puppeteer
  provider        = "prisma-erd-generator"
  output          = "../ERD.svg"
  puppeteerConfig = "puppeteerConfig.json"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_logs {
  id          Int      @id @default(autoincrement())
  user_id     Int?
  status_code Int?
  endpoint    String   @db.VarChar(250)
  method      String   @db.VarChar(10)
  body        String?  @db.Text /// @encrypted
  param       Json?    @db.Json
  query       Json?    @db.Json
  ip_address  String?  @db.VarChar(45)
  created_at  DateTime @default(now()) @db.Timestamptz(0)

  users users? @relation(fields: [user_id], references: [id], onDelete: Restrict)
}

model users {
  id         Int          @id @default(autoincrement())
  email      String       @unique
  role       UserRole     @default(USER)
  first_name String?
  last_name  String?
  dob        DateTime?
  username   String       @unique
  password   String /// @encrypted
  is_active  Boolean      @default(false)
  created_at DateTime     @default(now()) @db.Timestamptz(0)
  updated_at DateTime     @updatedAt @db.Timestamptz(0)
  auditLogs  audit_logs[]
}

model universities {
  id         Int         @id @default(autoincrement())
  name       String      @db.VarChar(255)
  location   String      @db.VarChar(100)
  state      String      @db.VarChar(100)
  created_at DateTime    @default(now()) @db.Timestamptz(0)
  faculties  faculties[]
}

model faculties {
  id                Int      @id @default(autoincrement())
  name              String   @db.VarChar(255)
  university_id     Int
  google_scholar_id String?  @db.VarChar(255)
  created_at        DateTime @default(now()) @db.Timestamptz(0)

  universities universities @relation(fields: [university_id], references: [id], onDelete: Cascade)
}

model publications {
  id               Int       @id @default(autoincrement())
  title            String    @db.VarChar(500)
  abstract         String?   @db.Text
  publication_date DateTime?
  faculties_id     String?   @db.VarChar(255)
  created_at       DateTime  @default(now()) @db.Timestamptz(0)
}

enum UserRole {
  ADMIN
  USER
}
